{
  "name": "financia-pro",
  "version": "6.2.1",
  "description": "Financia Pro Accounting Application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "author": "DEVELOPER-KALAM",
  "dependencies": {},
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.financia.pro",
    "productName": "Financia Pro",
    "directories": {
      "output": "dist"
    },
    "files": [
      "app.html",
      "splash.html",
      "main.js",
      "preload.js",
      "assets/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "Financia Pro",
      "createDesktopShortcut": true
    },
    "asar": true
  }
}
